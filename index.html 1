<script>
// ── Hilfsfunktionen ──
function showToast(msg){
  const t=document.getElementById('toast');
  t.textContent=msg;t.classList.add('show');
  setTimeout(()=>t.classList.remove('show'),3500);
}

// ── Zahlung ──
let paidStatus=false;
let selectedPlan='standard';

function selectPlan(plan){
  selectedPlan=plan;
  document.getElementById('plan-standard').classList.toggle('selected',plan==='standard');
  document.getElementById('plan-premium').classList.toggle('selected',plan==='premium');
  document.getElementById('pay-btn-text').textContent='€'+(plan==='standard'?'39,00':'59,00')+' bezahlen via PayPal';
}

function payWithPayPal(){
  const price=selectedPlan==='standard'?'39.00':'59.00';
  const item=selectedPlan==='standard'?'Festlich Standard':'Festlich Premium';
  const email='aljomaaahmad4@gmail.com';
  const ret=encodeURIComponent(window.location.href+'?paid=1');
  const cancel=encodeURIComponent(window.location.href);
  const url=`https://www.paypal.com/cgi-bin/webscr?cmd=_xclick&business=${email}&item_name=${encodeURIComponent(item)}&amount=${price}&currency_code=EUR&return=${ret}&cancel_return=${cancel}`;
  window.open(url,'_blank');
  document.getElementById('pay-step1').style.display='none';
  document.getElementById('pay-step2').style.display='block';
}

function confirmPayment(){
  paidStatus=true;
  document.getElementById('payModal').classList.remove('open');
  showStep(5);
  const em=document.getElementById('re').value||'Ihre E-Mail';
  document.getElementById('cem').textContent=em;
  sendConfirmationEmail(em,document.getElementById('rn').value||'');
  showToast('✓ Zahlung bestätigt! Premium freigeschaltet.');
}

// ── E-Mail (EmailJS) ──
// Nach emailjs.com Registrierung die 3 Werte unten ersetzen:
const EJ_SERVICE='IHRE_SERVICE_ID';
const EJ_TEMPLATE='IHRE_TEMPLATE_ID';
const EJ_KEY='IHR_PUBLIC_KEY';

function sendConfirmationEmail(toEmail,toName){
  if(EJ_SERVICE==='IHRE_SERVICE_ID')return;
  const names={'1':'Mono Klassik','2':'Floral','3':'Dark Elegant','4':'Zartes Rosé','5':'Waldgrün Boho','6':'Art Déco Gold','7':'Neon Cyber','8':'Holografisch','9':'Brutalist Gelb'};
  const tplEl=document.querySelector('input[name="tpl"]:checked');
  if(typeof emailjs!=='undefined'){
    emailjs.init(EJ_KEY);
    emailjs.send(EJ_SERVICE,EJ_TEMPLATE,{
      to_email:toEmail,
      to_name:toName,
      template_name:tplEl?(names[tplEl.value]||'Vorlage'):'Vorlage',
      event_date:selDate?selDate.toLocaleDateString('de-DE'):'—',
      host_name:document.getElementById('dhost')?.value||'',
      venue_name:document.getElementById('dvenue')?.value||'',
      plan:paidStatus?(selectedPlan==='premium'?'Premium (€59)':'Standard (€39)'):'Gratis'
    });
  }
}

// ── Editor öffnen ──
function openEditor(){
  closeModal();
  // Daten aus Formular holen
  const host=document.getElementById('dhost')?.value||'Ihre Namen';
  const venue=document.getElementById('dvenue')?.value||'Ihre Location';
  const city=document.getElementById('dcity')?.value||'';
  const dateStr=selDate?selDate.toLocaleDateString('de-DE',{day:'numeric',month:'long',year:'numeric'}):'—';
  const time=document.getElementById('dtime')?.value||'';
  // In Editor übertragen
  const edHost=document.getElementById('ed-host');
  const edDate=document.getElementById('ed-date');
  const edVenue=document.getElementById('ed-venue');
  const edLink=document.getElementById('ed-link');
  if(edHost) edHost.textContent=host;
  if(edDate) edDate.textContent=dateStr+(time?' um '+time:'');
  if(edVenue) edVenue.textContent=venue+(city?', '+city:'');
  if(edLink) edLink.value=window.location.origin+'/?einladung='+btoa(host).replace(/=/g,'').substring(0,8);
  // Editor anzeigen, Hauptseite verstecken
  const editor=document.getElementById('editorPage');
  const main=document.getElementById('mainContent');
  if(editor) editor.style.display='block';
  if(main) main.style.display='none';
  window.scrollTo(0,0);
}

function closeEditor(){
  const editor=document.getElementById('editorPage');
  const main=document.getElementById('mainContent');
  if(editor) editor.style.display='none';
  if(main) main.style.display='block';
}

function copyLink(){
  const inp=document.getElementById('ed-link');
  if(inp){inp.select();document.execCommand('copy');showToast('✓ Link kopiert!');}
}

function shareWhatsApp(){
  const link=document.getElementById('ed-link')?.value||window.location.href;
  const host=document.getElementById('ed-host')?.textContent||'';
  const date=document.getElementById('ed-date')?.textContent||'';
  const msg=encodeURIComponent('🎉 Einladung von '+host+'\n📅 '+date+'\n\n'+link);
  window.open('https://wa.me/?text='+msg,'_blank');
}

// ── Navigation durch Schritte ──
function go(n){
  if(n>cur&&!validate(cur))return;
  if(cur===4&&n===5){
    const v=document.querySelector('input[name="tpl"]:checked')?.value;
    if(['6','7','8','9'].includes(v)&&!paidStatus){
      document.getElementById('payModal').classList.add('open');
      return;
    }
  }
  showStep(n);
  if(n===5){
    const em=document.getElementById('re').value||'Ihre E-Mail';
    document.getElementById('cem').textContent=em;
    sendConfirmationEmail(em,document.getElementById('rn').value||'');
  }
}

function validate(s){
  if(s===1){
    let ok=true;
    const nm=document.getElementById('rn').value.trim(),em=document.getElementById('re').value.trim(),agb=document.getElementById('agb').checked;
    document.getElementById('en').style.display=nm?'none':'block';if(!nm)ok=false;
    document.getElementById('ee').style.display=(em&&em.includes('@'))?'none':'block';if(!em||!em.includes('@'))ok=false;
    document.getElementById('eagb').style.display=agb?'none':'block';if(!agb)ok=false;
    return ok;
  }
  if(s===2){const p=document.querySelector('input[name="tpl"]:checked');document.getElementById('etpl').style.display=p?'none':'block';return!!p;}
  if(s===3){const ok=!!selDate;document.getElementById('edate').style.display=ok?'none':'block';return ok;}
  if(s===4){const h=document.getElementById('dhost').value.trim(),v=document.getElementById('dvenue').value.trim(),ok=!!(h&&v);document.getElementById('edet').style.display=ok?'none':'block';return ok;}
  return true;
}

function chkPw(v){
  const f=document.getElementById('pwf'),h=document.getElementById('pwh');let s=0;
  if(v.length>=8)s++;if(/[A-Z]/.test(v))s++;if(/[0-9]/.test(v))s++;if(/[^A-Za-z0-9]/.test(v))s++;
  f.style.width=[0,25,50,75,100][s]+'%';
  f.style.background=['#ccc','#e67e22','#f1c40f','#27ae60','#111'][s];
  h.textContent=['Mindestens 8 Zeichen','Schwach','Mittel','Gut','Stark'][s];
}

function pickT(id){document.querySelectorAll('.tpick').forEach(t=>t.classList.remove('chosen'));document.getElementById(id).classList.add('chosen');}

// ── Kalender ──
let calD=new Date(),selDate=null;
const months=['Januar','Februar','März','April','Mai','Juni','Juli','August','September','Oktober','November','Dezember'];
const dnames=['Mo','Di','Mi','Do','Fr','Sa','So'];

function renderCal(){
  const d=new Date(calD.getFullYear(),calD.getMonth(),1);
  document.getElementById('calMn').textContent=months[d.getMonth()]+' '+d.getFullYear();
  const g=document.getElementById('calG');g.innerHTML='';
  dnames.forEach(dn=>{const el=document.createElement('div');el.className='cal-dn';el.textContent=dn;g.appendChild(el);});
  let st=(d.getDay()+6)%7;
  for(let i=0;i<st;i++){const e=document.createElement('div');e.className='cal-d em';g.appendChild(e);}
  const dim=new Date(d.getFullYear(),d.getMonth()+1,0).getDate();
  const today=new Date();
  for(let i=1;i<=dim;i++){
    const cell=document.createElement('div'),td=new Date(d.getFullYear(),d.getMonth(),i);
    const past=td<new Date(today.getFullYear(),today.getMonth(),today.getDate());
    const isT=td.toDateString()===today.toDateString();
    const isSel=selDate&&td.toDateString()===selDate.toDateString();
    cell.className='cal-d'+(past?' pa':'')+(isT?' tod':'')+(isSel?' sel':'');
    cell.textContent=i;
    if(!past)cell.onclick=()=>selD2(new Date(d.getFullYear(),d.getMonth(),i));
    g.appendChild(cell);
  }
}

function selD2(d){
  selDate=d;renderCal();
  const el=document.getElementById('selD');
  el.style.display='flex';
  document.getElementById('selDt').textContent=d.getDate()+'. '+months[d.getMonth()]+' '+d.getFullYear();
}

function cPrev(){calD=new Date(calD.getFullYear(),calD.getMonth()-1,1);renderCal();}
function cNext(){calD=new Date(calD.getFullYear(),calD.getMonth()+1,1);renderCal();}

// ── Modal ──
let cur=1;
const titles=['','Konto erstellen','Vorlage wählen','Datum auswählen','Ort & Details','Fertig! 🎉'];
const subs=['','Schritt 1 von 4','Schritt 2 von 4','Schritt 3 von 4','Schritt 4 von 4','Einladung bereit'];

function openModal(t){
  cur=1;
  document.getElementById('mainModal').classList.add('open');
  document.body.style.overflow='hidden';
  document.getElementById('mtit').textContent=t==='login'?'Anmelden':'Konto erstellen';
  document.getElementById('msub2').textContent=t==='login'?'Willkommen zurück':'Kostenlos starten — kein Risiko';
  renderCal();showStep(1);
}

function closeModal(){document.getElementById('mainModal').classList.remove('open');document.body.style.overflow='';}
document.getElementById('mainModal').addEventListener('click',function(e){if(e.target===this)closeModal();});

function showStep(n){
  [1,2,3,4,5].forEach(i=>{
    document.getElementById('step'+i).classList.toggle('active',i===n);
    const p=document.getElementById('ps'+i);if(p)p.classList.toggle('done',i<=n);
  });
  document.getElementById('mtit').textContent=titles[n];
  document.getElementById('msub2').textContent=subs[n];
  document.getElementById('prog').style.display=n===5?'none':'flex';
  document.getElementById('mbox').scrollTop=0;
  cur=n;
}

// ── Nav Schatten ──
window.addEventListener('scroll',()=>{
  document.getElementById('nav').style.boxShadow=window.scrollY>30?'0 2px 20px rgba(0,0,0,.07)':'';
});

// ── PayPal Rückkehr erkennen ──
window.addEventListener('DOMContentLoaded',()=>{
  if(new URLSearchParams(window.location.search).get('paid')==='1'){
    paidStatus=true;
    showToast('✓ Zahlung erhalten! Premium ist aktiv.');
  }
});
</script>


